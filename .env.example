# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Local development (Docker Compose):
POSTGRES_USER=YOUR_DB_USER
POSTGRES_PASSWORD=YOUR_DB_PASSWORD
POSTGRES_DB=ndtv_dam
DATABASE_URL=postgresql+asyncpg://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/ndtv_dam

# Production (Neon — must include ?sslmode=require):
# DATABASE_URL=postgresql+asyncpg://YOUR_USER:YOUR_PASSWORD@ep-xxx.us-east-1.aws.neon.tech/ndtv_dam?sslmode=require

# ─── Qdrant Vector Store ──────────────────────────────────────────────────────
# Local:
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=           # Leave blank for local; required for Qdrant Cloud
# QDRANT_USE_HTTPS=false    # Set to true for Qdrant Cloud

# Production (Qdrant Cloud):
# QDRANT_HOST=https://YOUR-CLUSTER-ID.us-east4-0.gcp.cloud.qdrant.io
# QDRANT_API_KEY=YOUR_QDRANT_API_KEY
# QDRANT_USE_HTTPS=true

# ─── Redis / Celery ───────────────────────────────────────────────────────────
# Local:
REDIS_URL=redis://localhost:6379/0

# Production (Upstash — note: rediss:// with TLS, the extra 's' is not a typo):
# REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR-HOST.upstash.io:6379

# ─── File Storage ─────────────────────────────────────────────────────────────
# Local only — ignored when R2 is configured:
UPLOAD_DIR=/data/uploads

# Cloudflare R2 (leave all blank to use local disk):
# R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
# R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
# R2_BUCKET_NAME=ndtv-dam-uploads
# R2_PUBLIC_URL=https://pub-YOUR_TOKEN.r2.dev   # Only if bucket is set to public

# ─── AI Models ────────────────────────────────────────────────────────────────
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
INSIGHTFACE_MODEL=buffalo_l

# ─── Face Recognition Thresholds ─────────────────────────────────────────────
# Cosine similarity >= this → recognized
CONFIDENCE_FACE_THRESHOLD=0.45
# Cosine similarity in [this, FACE_THRESHOLD) → low_confidence (sent to review)
CONFIDENCE_LOW_THRESHOLD=0.35

# ─── Upload Limits ────────────────────────────────────────────────────────────
MAX_UPLOAD_BATCH_SIZE=500
# Max file size per image in bytes (20 MB)
MAX_FILE_SIZE_BYTES=20971520
# Minimum image dimension (width or height)
MIN_IMAGE_DIMENSION=200

# ─── Shortlisting ─────────────────────────────────────────────────────────────
SHORTLIST_COUNT=5

# ─── Quality Scoring Thresholds ───────────────────────────────────────────────
QUALITY_SHARPNESS_MIN=80.0
QUALITY_BRIGHTNESS_MIN=60
QUALITY_BRIGHTNESS_MAX=210

# ─── Asset Variants ───────────────────────────────────────────────────────────
BRAND_LOGO_PATH=/assets/ndtv_profit_logo.png
VARIANT_SQUARE_SIZE=1000

# ─── Duplicate Detection ──────────────────────────────────────────────────────
PHASH_DUPLICATE_THRESHOLD=8

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Set FRONTEND_URL to your Vercel deployment URL in production (required for CORS):
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
